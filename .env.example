# ScaleMargin Dispatch Handler — Environment Variables
# Copy this to .env and fill in your values

# Server
PORT=3100

# Email provider: "ses" or "sendgrid"
EMAIL_PROVIDER=ses

# Sender email address (must be verified in your provider)
FROM_EMAIL=campaigns@your-domain.com

# ScaleMargin HMAC secrets (provided by ScaleMargin when you configure webhooks in Atlas)
SCALEMARGIN_DISPATCH_SECRET=your-dispatch-secret-here
SCALEMARGIN_ANALYTICS_SECRET=your-analytics-secret-here
# Optional: platform analytics POST URL when SES (or other) events have no per-send callback in memory.
# Same URL for all orgs is fine — routing uses signed payload campaign_id + organization_id.
# Example: https://<scalemargin-api-host>/api/webhooks/campaign-analytics
# SCALEMARGIN_ANALYTICS_CALLBACK_URL=https://api.your-scalemargin.example/api/webhooks/campaign-analytics
# When Atlas/dispatch sends a different analytics_callback_url (e.g. prod) but you forward locally, set:
# SCALEMARGIN_ANALYTICS_CALLBACK_URL_OVERRIDES_DISPATCH=1
# so SCALEMARGIN_ANALYTICS_CALLBACK_URL wins for dispatch emits, SendGrid custom_args, and inbound resolution.

# Local-only: with pnpm run dev:local, missing SCALEMARGIN_* get insecure placeholders (HTTP mock / local UI only).
# LOCAL_DEV=1

# Unsubscribe URL base (your domain's unsubscribe handler)
# Unsubscribe link in mail templates (dispatch placeholders). For local “double proxy” with ngrok, set to
# https://<your-tunnel>/api/unsubscribe — same host as SendGrid webhook + analytics capture (no /scalemargin/ in this URL).
UNSUBSCRIBE_URL_BASE=https://your-domain.com/unsubscribe
# Optional: when set, GET /api/unsubscribe POSTs PII-free `unsubscribed` analytics here (same HMAC as pipeline).
# UNSUBSCRIBE_LINK_ANALYTICS_URL=https://your-tunnel/api/webhooks/campaign-analytics/capture
# Optional: after recording, redirect the browser (e.g. main product confirmation page).
# UNSUBSCRIBE_LINK_REDIRECT_URL=https://your-main-app.example/unsubscribed

# --- Dev/Staging only ---
# Route ALL emails to a single test address (remove in production!)
# DEV_RECIPIENT_EMAIL=test@example.com

# --- AWS SES (when EMAIL_PROVIDER=ses) ---
# Full guide: docs/ses.readme.md — configuration set + SNS + pnpm run dev:ses-event-test
# Use only ONE AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY pair (duplicate lines confuse tooling).
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
# Or use IAM roles on EC2/ECS/Lambda (recommended for production)

# --- SendGrid (when EMAIL_PROVIDER=sendgrid) ---
# Full guide: docs/sendgrid.readme.md
# SENDGRID_API_KEY=SG.your-api-key-here

# --- User lookup + personalization (config/dispatch.yaml) ---
# Path to YAML (default: ./config/dispatch.yaml). If missing, mock lookup + default placeholders are used.
# USER_LOOKUP_CONFIG_PATH=./config/dispatch.yaml
# Overrides backend in YAML: mock | mysql | postgres | sqlite | http
# USER_LOOKUP_BACKEND=mock

# --- SQL backends (mysql / postgres / sqlite) ---
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your-password
# DB_NAME=customers
# DB_SSL=true
# For SQLite file path when not set in YAML (default seed: ./data/dispatch.sqlite)
# DB_FILE=./data/dispatch.sqlite
# Allow empty DB password (local dev only)
# DB_ALLOW_EMPTY_PASSWORD=true

# --- HTTP user lookup (when USER_LOOKUP_BACKEND=http) ---
# PROFILE_API_TOKEN=your-server-to-server-token
# Local mock profile API: pnpm run dev:http-profile-mock (see docs/testing.md)
# PROFILE_MOCK_PORT=4310
# PROFILE_MOCK_TOKEN=my-local-secret   # optional; if set, curl/dispatch must send Bearer

# --- Event pipeline (SendGrid / SES / Gupshup webhooks → ScaleMargin analytics) ---
# Optional path to YAML (default: ./config/events.yaml if present; otherwise built-in defaults).
# EVENTS_CONFIG_PATH=./config/events.yaml
#
# Provider on/off is driven by env (not only YAML): SendGrid enables when SENDGRID_EVENT_WEBHOOK_PUBLIC_KEY is set;
# Gupshup when GUPSHUP_WEBHOOK_SECRET is set; SES stays on unless listed in DISABLED.
# EVENT_PROVIDERS_DISABLED=sendgrid,ses,gupshup   # comma list — force-disable after auto-detect
# EVENT_PROVIDERS_ENABLED=sendgrid               # comma list — force-enable listed providers (still need keys where required)
# EVENT_DEBUG=1                                  # boot “resolved config” + emit/flush verbose logs ([Events], [Forwarder] from client)
#
# Overrides for events config (see config/events.example.yaml):
# EVENT_DELIVERY_MODE=at_least_once       # at_least_once | best_effort
# EVENT_FORWARD_MODE=batched              # batched | sync
# EVENT_BATCH_SIZE=100
# EVENT_BATCH_INTERVAL_MS=5000
# EVENT_BUFFER_DIR=./data/event-buffer    # if set, switches buffer to disk and uses this directory
# EVENT_SENDGRID_INBOUND_EVENTS=default   # default minimal wires | * or all | comma list e.g. delivered,open
# EVENT_PREFERENCE_SIMULATION_LOG=0       # set to 0 to disable [Events][PreferenceSimulation] console lines (unsubscribed, complained)
#
# Per-provider secrets (required when that provider is enabled — auto from keys above):
# SENDGRID_EVENT_WEBHOOK_PUBLIC_KEY=      # base64 ECDSA public key from SendGrid Event Webhook settings (presence enables inbound + outbound tagging path)
# SES_EVENT_CONFIG_SET=                   # SES Configuration Set name for outbound tagging (SNS events)
# GUPSHUP_WEBHOOK_SECRET=                 # optional shared secret for Gupshup inbound webhook HMAC.
#                                         # POST /api/scalemargin/gupshup-events ALWAYS logs the raw payload.
#                                         # Forwarding to the backend event caller is OFF by default (log only).
#                                         # Set this secret (HMAC verified) — or EVENT_PROVIDERS_ENABLED=gupshup
#                                         # (open, no verify) — to turn forwarding on later.
#
# Local dual-secret + SendGrid smoke test (see docs/event-dual-secret-local-test.md, pnpm run dev:event-test):
# EVENT_TEST_CSV_PATH=./data/event-test-capture.csv
# Local dual-secret + SES smoke test (see docs/ses.readme.md, pnpm run dev:ses-event-test):
# SES_EVENT_TEST_CSV_PATH=./data/ses-event-test-capture.csv
# Local Gupshup WhatsApp + webhook smoke test (pnpm run dev:gupshup-event-test):
# Outbound auth — use ONE of:
# GUPSHUP_API_KEY=                         # io template API (also set GUPSHUP_SRC_NAME + GUPSHUP_SOURCE)
# GUPSHUP_USER_ID=                         # enterprise SendMessage at https://smsgupshup.com
# GUPSHUP_PASSWORD=
# GUPSHUP_MESSAGE_TYPE=HSM                 # enterprise msg_type (default HSM)
# GUPSHUP_TEMPLATE_LANGUAGE=en             # template language in enterprise `msg` JSON
# GUPSHUP_ENTERPRISE_API_URL=https://smsgupshup.com
# GUPSHUP_TEMPLATE_API_URL=https://api.gupshup.io/wa/api/v1/template/msg
# GUPSHUP_DEFAULT_TEMPLATE={"id":"<template-uuid>","params":["{{first_name}}"]}
# GUPSHUP_SRC_NAME=YourAppName             # io API src.name
# GUPSHUP_SOURCE=918971741003              # io API WABA sender (digits only)
# GUPSHUP_EVENT_TEST_SRC_NAME=YourAppName  # test script alias for GUPSHUP_SRC_NAME
# GUPSHUP_EVENT_TEST_SOURCE=918971741003   # test script alias for GUPSHUP_SOURCE
# GUPSHUP_MEDIA_API_URL=https://mediaapi.smsgupshup.com/GatewayAPI/rest
# GUPSHUP_MEDIA_MSG_TYPE=IMAGE              # SENDMEDIAMESSAGE msg_type (default IMAGE)
# GUPSHUP_EVENT_TEST_CAPTION="Dear {{first_name}},\n\nYour message here..."   # plain text; use \n for line breaks (encoded at GatewayAPI send)
# GUPSHUP_EVENT_TEST_MEDIA_URL=https://cdn.example/image.png   # plain HTTPS URL (encoded at GatewayAPI send)
# GUPSHUP_EVENT_TEST_TEMPLATE={"id":"<template-uuid>","params":["{{first_name}}"]}  # when no caption
# GUPSHUP_EVENT_TEST_RECIPIENTS=919876543210   # dev/staging: route all WhatsApp sends to first number
# GUPSHUP_EVENT_TEST_CSV_PATH=./data/gupshup-event-test-capture.csv
# GUPSHUP_EVENT_TEST_SKIP_SEND=1           # 1 = start server only, no template API POST
# GUPSHUP_EVENT_TEST_LOG_PAYLOAD=0         # set 0 to silence full outbound request logs during dev:gupshup-event-test
# GUPSHUP_EVENT_TEST_LOG_PAYLOAD=1         # print full outbound request to terminal (default on when GUPSHUP_EVENT_TEST_RECIPIENTS is set)
# GUPSHUP_EVENT_TEST_OMIT_TAG=1            # 1 = do not send form field `tag` (if Gupshup API rejects unknown fields)
# EVENT_TEST_PUBLIC_BASE_URL=https://your-tunnel.example
# EVENT_TEST_RECIPIENTS=a@x.com,b@y.com
# EVENT_TEST_KEEP_WORKDIR=1
# EVENT_TEST_AUTO_DISPATCH=0   # default: auto POST /dispatch after server is up; 0 = only print curl

# --- Image Hosting (optional — for full privacy compliance) ---
# Without this, images are served from ScaleMargin's infrastructure.
# Set IMAGE_STORAGE_PROVIDER to re-host images on your own S3/GCS.
# IMAGE_STORAGE_PROVIDER=s3     # "s3", "gcs", or "local" (local = dev only)

# AWS S3 (when IMAGE_STORAGE_PROVIDER=s3):
# IMAGE_S3_BUCKET=my-campaign-images
# IMAGE_S3_REGION=ap-south-1
# IMAGE_S3_PREFIX=campaign-images/
# IMAGE_CDN_BASE_URL=https://cdn.your-domain.com  # Optional: CloudFront/CDN URL

# Google Cloud Storage (when IMAGE_STORAGE_PROVIDER=gcs):
# IMAGE_GCS_BUCKET=my-campaign-images
# IMAGE_GCS_PREFIX=campaign-images/
# IMAGE_GCS_PROJECT_ID=my-project
# IMAGE_GCS_CREDENTIALS_JSON={"type":"service_account",...}  # Or use ADC on GCE/GKE
# IMAGE_CDN_BASE_URL=https://cdn.your-domain.com  # Optional: Cloud CDN URL
