# ScaleMargin Dispatch Handler — Environment Variables
# Copy this to .env and fill in your values

# Server
PORT=3100

# Email provider: "ses" or "sendgrid"
EMAIL_PROVIDER=ses

# Sender email address (must be verified in your provider)
FROM_EMAIL=campaigns@your-domain.com

# ScaleMargin HMAC secrets (provided by ScaleMargin when you configure webhooks in Atlas)
SCALEMARGIN_DISPATCH_SECRET=your-dispatch-secret-here
SCALEMARGIN_ANALYTICS_SECRET=your-analytics-secret-here

# Local-only: with pnpm run dev:local, missing SCALEMARGIN_* get insecure placeholders (HTTP mock / local UI only).
# LOCAL_DEV=1

# Unsubscribe URL base (your domain's unsubscribe handler)
UNSUBSCRIBE_URL_BASE=https://your-domain.com/unsubscribe

# --- Dev/Staging only ---
# Route ALL emails to a single test address (remove in production!)
# DEV_RECIPIENT_EMAIL=test@example.com

# --- AWS SES (when EMAIL_PROVIDER=ses) ---
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
# Or use IAM roles on EC2/ECS/Lambda (recommended for production)

# --- SendGrid (when EMAIL_PROVIDER=sendgrid) ---
# SENDGRID_API_KEY=SG.your-api-key-here

# --- User lookup + personalization (config/dispatch.yaml) ---
# Path to YAML (default: ./config/dispatch.yaml). If missing, mock lookup + default placeholders are used.
# USER_LOOKUP_CONFIG_PATH=./config/dispatch.yaml
# Overrides backend in YAML: mock | mysql | postgres | sqlite | http
# USER_LOOKUP_BACKEND=mock

# --- SQL backends (mysql / postgres / sqlite) ---
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your-password
# DB_NAME=customers
# DB_SSL=true
# For SQLite file path when not set in YAML (default seed: ./data/dispatch.sqlite)
# DB_FILE=./data/dispatch.sqlite
# Allow empty DB password (local dev only)
# DB_ALLOW_EMPTY_PASSWORD=true

# --- HTTP user lookup (when USER_LOOKUP_BACKEND=http) ---
# PROFILE_API_TOKEN=your-server-to-server-token
# Local mock profile API: pnpm run dev:http-profile-mock (see docs/testing.md)
# PROFILE_MOCK_PORT=4310
# PROFILE_MOCK_TOKEN=my-local-secret   # optional; if set, curl/dispatch must send Bearer

# --- Image Hosting (optional — for full privacy compliance) ---
# Without this, images are served from ScaleMargin's infrastructure.
# Set IMAGE_STORAGE_PROVIDER to re-host images on your own S3/GCS.
# IMAGE_STORAGE_PROVIDER=s3     # "s3", "gcs", or "local" (local = dev only)

# AWS S3 (when IMAGE_STORAGE_PROVIDER=s3):
# IMAGE_S3_BUCKET=my-campaign-images
# IMAGE_S3_REGION=ap-south-1
# IMAGE_S3_PREFIX=campaign-images/
# IMAGE_CDN_BASE_URL=https://cdn.your-domain.com  # Optional: CloudFront/CDN URL

# Google Cloud Storage (when IMAGE_STORAGE_PROVIDER=gcs):
# IMAGE_GCS_BUCKET=my-campaign-images
# IMAGE_GCS_PREFIX=campaign-images/
# IMAGE_GCS_PROJECT_ID=my-project
# IMAGE_GCS_CREDENTIALS_JSON={"type":"service_account",...}  # Or use ADC on GCE/GKE
# IMAGE_CDN_BASE_URL=https://cdn.your-domain.com  # Optional: Cloud CDN URL
