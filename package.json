{
  "name": "scalemargin-dispatch-handler",
  "version": "1.0.0",
  "description": "Reference implementation for ScaleMargin webhook dispatch handler and analytics reporter. Supports AWS SES and SendGrid.",
  "packageManager": "pnpm@9.15.4",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:local": "LOCAL_DEV=1 tsx watch src/index.ts",
    "dev:http-profile-mock": "tsx scripts/http-profile-mock-server.ts",
    "dev:event-test": "tsx scripts/event-dual-secret-test-server.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:coverage": "vitest run --coverage",
    "seed:mysql": "tsx scripts/seed/seed.ts --dialect=mysql",
    "seed:postgres": "tsx scripts/seed/seed.ts --dialect=postgres",
    "seed:sqlite": "tsx scripts/seed/seed.ts --dialect=sqlite"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/client-ses": "^3.700.0",
    "@google-cloud/storage": "^7.14.0",
    "@sendgrid/eventwebhook": "^8.0.0",
    "@sendgrid/mail": "^8.1.4",
    "better-sqlite3": "^11.8.0",
    "express": "^4.21.0",
    "js-yaml": "^4.1.0",
    "kysely": "^0.27.5",
    "mysql2": "^3.11.0",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "starkbank-ecdsa": "^1.1.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.4"
  }
}
